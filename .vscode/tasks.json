{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "yarn: install + lint",
      "type": "shell",
      "command": "yarn install --immutable && yarn lint",
      "problemMatcher": ["$eslint-stylish"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "yarn: build",
      "type": "shell",
      "command": "yarn build",
      "group": "build",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "yarn: test",
      "type": "shell",
      "command": "yarn test",
      "group": "test",
      "problemMatcher": ["$karma"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Run MCP Server",
      "type": "shell",
      "command": "npx mcp-server --watch",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
