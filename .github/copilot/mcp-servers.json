{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "Context7_API_KEY": "${COPILOT_MCP_CONTEXT7}"
      },
      "tools": ["get-library-docs", "resolve-library-id"]
    },
    "server-sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@sequential-thinking/mcp-server"]
    },
    "software-planning-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@software-planning-tool/mcp-server"]
    },
    "server-everything": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"]
    },
    "server-filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "--base-path", "."]
    },
    "playwright-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "playwright-mcp-server"]
    },
    "server-time": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"]
    },
    "server-fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    }
  }
}
