{
  "name": "@ng-events/core-engine",
  "version": "1.0.0",
  "description": "Pure domain core with event sourcing and causality tracking - ZERO framework dependencies. Frontend & backend agnostic, no firebase-admin or @angular/fire.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "ddd",
    "event-sourcing",
    "causality",
    "domain-driven-design",
    "cqrs",
    "core",
    "pure-domain"
  ],
  "author": "ng-events team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "tsconfig": {
    "compilerOptions": {
      "baseUrl": ".",
      "paths": {
        "firebase-admin": [
          "__forbidden__"
        ],
        "@angular/fire": [
          "__forbidden__"
        ],
        "@ng-events/platform-adapters/*": [
          "__forbidden__"
        ]
      }
    }
  },
  "copilot": {
    "notes": [
      "core-engine is PURE domain logic",
      "No framework or SDK dependencies allowed",
      "Do NOT import firebase-admin or @angular/fire",
      "Can be used in both frontend or backend via safe adapters"
    ]
  },
  "dependencies": {
    "@ng-events/account-domain": "*"
  }
}
