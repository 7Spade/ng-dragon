{
  "name": "@ng-events/account-domain",
  "version": "1.0.0",
  "description": "Account / Workspace / Membership / Module registry domain models (pure TypeScript, frontend & backend safe, no firebase-admin)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "ddd",
    "account",
    "workspace",
    "membership",
    "module-registry",
    "domain"
  ],
  "author": "ng-events team",
  "license": "MIT",
  "dependencies": {
    "@ng-events/core-engine": "*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "tsconfig": {
    "compilerOptions": {
      "baseUrl": ".",
      "paths": {
        "firebase-admin": ["__forbidden__"]
      }
    }
  },
  "copilot": {
    "notes": [
      "account-domain is pure TypeScript domain layer",
      "Safe for frontend & backend",
      "Do NOT import firebase-admin here",
      "Use only core-engine or other domain-safe packages"
    ]
  }
}
